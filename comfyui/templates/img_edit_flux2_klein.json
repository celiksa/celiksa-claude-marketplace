{
  "_meta": {
    "name": "img_edit_flux2_klein",
    "description": "Image editing using Flux 2 Klein 4B with reference conditioning. Edit images based on text descriptions while preserving the original image's structure.",
    "category": "img2img",
    "requires_input_image": true,
    "parameters": {
      "prompt": {"node": "74", "field": "inputs.text"},
      "seed": {"node": "73", "field": "inputs.noise_seed", "default": 0},
      "steps": {"node": "62", "field": "inputs.steps", "default": 20},
      "cfg": {"node": "63", "field": "inputs.cfg", "default": 5},
      "input_image": {"node": "load_image", "field": "inputs.image", "description": "Filename of uploaded image (set by upload handler)"}
    },
    "models": {
      "diffusion_models": "flux-2-klein-4b-nvfp4.safetensors",
      "text_encoders": "qwen_3_4b.safetensors",
      "vae": "flux2-vae.safetensors"
    },
    "model_downloads": {
      "flux-2-klein-4b-nvfp4.safetensors": {
        "url": "https://huggingface.co/black-forest-labs/FLUX.2-klein-base-4b-fp8/resolve/main/flux-2-klein-4b-nvfp4.safetensors",
        "category": "diffusion_models",
        "size_mb": 4200
      }
    }
  },
  "70": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "flux-2-klein-4b-nvfp4.safetensors",
      "weight_dtype": "default"
    }
  },
  "71": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "qwen_3_4b.safetensors",
      "type": "flux2",
      "device": "default"
    }
  },
  "72": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "flux2-vae.safetensors"
    }
  },
  "load_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": ""
    }
  },
  "80": {
    "class_type": "ImageScaleToTotalPixels",
    "inputs": {
      "image": ["load_image", 0],
      "upscale_method": "nearest-exact",
      "megapixels": 1,
      "resolution_steps": 16
    }
  },
  "81": {
    "class_type": "GetImageSize",
    "inputs": {
      "image": ["80", 0]
    }
  },
  "74": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["71", 0],
      "text": ""
    }
  },
  "67": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["71", 0],
      "text": ""
    }
  },
  "78": {
    "class_type": "VAEEncode",
    "inputs": {
      "pixels": ["80", 0],
      "vae": ["72", 0]
    }
  },
  "77": {
    "class_type": "ReferenceLatent",
    "inputs": {
      "conditioning": ["74", 0],
      "latent": ["78", 0]
    }
  },
  "76": {
    "class_type": "ReferenceLatent",
    "inputs": {
      "conditioning": ["67", 0],
      "latent": ["78", 0]
    }
  },
  "66": {
    "class_type": "EmptyFlux2LatentImage",
    "inputs": {
      "width": ["81", 0],
      "height": ["81", 1],
      "batch_size": 1
    }
  },
  "62": {
    "class_type": "Flux2Scheduler",
    "inputs": {
      "steps": 20,
      "width": ["81", 0],
      "height": ["81", 1]
    }
  },
  "63": {
    "class_type": "CFGGuider",
    "inputs": {
      "model": ["70", 0],
      "positive": ["77", 0],
      "negative": ["76", 0],
      "cfg": 5
    }
  },
  "61": {
    "class_type": "KSamplerSelect",
    "inputs": {
      "sampler_name": "euler"
    }
  },
  "73": {
    "class_type": "RandomNoise",
    "inputs": {
      "noise_seed": 0
    }
  },
  "64": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": ["73", 0],
      "guider": ["63", 0],
      "sampler": ["61", 0],
      "sigmas": ["62", 0],
      "latent_image": ["66", 0]
    }
  },
  "65": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["64", 0],
      "vae": ["72", 0]
    }
  },
  "save": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "img-edit",
      "images": ["65", 0]
    }
  }
}
