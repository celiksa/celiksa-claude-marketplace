{
  "_meta": {
    "name": "pose2img_z_image_turbo",
    "description": "Pose-guided image generation using Z-Image-Turbo + ControlNet Union. Generate images following the pose/structure of an input image.",
    "category": "controlnet",
    "requires_input_image": true,
    "parameters": {
      "prompt": {"node": "23", "field": "inputs.text"},
      "seed": {"node": "19", "field": "inputs.seed", "default": 0},
      "steps": {"node": "19", "field": "inputs.steps", "default": 9},
      "strength": {"node": "21", "field": "inputs.strength", "default": 1.0},
      "input_image": {"node": "load_image", "field": "inputs.image"}
    },
    "models": {
      "diffusion_models": "z_image_turbo_nvfp4.safetensors",
      "text_encoders": "qwen_3_4b.safetensors",
      "vae": "ae.safetensors",
      "model_patches": "Z-Image-Turbo-Fun-Controlnet-Union.safetensors"
    },
    "model_downloads": {
      "Z-Image-Turbo-Fun-Controlnet-Union.safetensors": {
        "url": "https://huggingface.co/Comfy-Org/z_image_turbo/resolve/main/split_files/model_patches/Z-Image-Turbo-Fun-Controlnet-Union.safetensors",
        "category": "model_patches",
        "size_mb": 1300
      }
    }
  },
  "load_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": ""
    }
  },
  "25": {
    "class_type": "GetImageSize",
    "inputs": {
      "image": ["load_image", 0]
    }
  },
  "15": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "z_image_turbo_nvfp4.safetensors",
      "weight_dtype": "default"
    }
  },
  "14": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "qwen_3_4b.safetensors",
      "type": "lumina2",
      "device": "default"
    }
  },
  "16": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "17": {
    "class_type": "ModelPatchLoader",
    "inputs": {
      "name": "Z-Image-Turbo-Fun-Controlnet-Union.safetensors"
    }
  },
  "21": {
    "class_type": "QwenImageDiffsynthControlnet",
    "inputs": {
      "model": ["15", 0],
      "model_patch": ["17", 0],
      "vae": ["16", 0],
      "image": ["load_image", 0],
      "strength": 1.0
    }
  },
  "18": {
    "class_type": "ModelSamplingAuraFlow",
    "inputs": {
      "model": ["21", 0],
      "shift": 3
    }
  },
  "23": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["14", 0],
      "text": ""
    }
  },
  "20": {
    "class_type": "ConditioningZeroOut",
    "inputs": {
      "conditioning": ["23", 0]
    }
  },
  "22": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": ["25", 0],
      "height": ["25", 1],
      "batch_size": 1
    }
  },
  "19": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["18", 0],
      "positive": ["23", 0],
      "negative": ["20", 0],
      "latent_image": ["22", 0],
      "seed": 0,
      "steps": 9,
      "cfg": 1,
      "sampler_name": "res_multistep",
      "scheduler": "simple",
      "denoise": 1
    }
  },
  "24": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["19", 0],
      "vae": ["16", 0]
    }
  },
  "save": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "pose-ctrl",
      "images": ["24", 0]
    }
  }
}
