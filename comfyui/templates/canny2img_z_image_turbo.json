{
  "_meta": {
    "name": "canny2img_z_image_turbo",
    "description": "Canny edge-guided image generation using Z-Image-Turbo + ControlNet Union. Extract edges from input image and generate a new image following that structure.",
    "category": "controlnet",
    "requires_input_image": true,
    "parameters": {
      "prompt": {"node": "12", "field": "inputs.text"},
      "seed": {"node": "7", "field": "inputs.seed", "default": 0},
      "steps": {"node": "7", "field": "inputs.steps", "default": 9},
      "low_threshold": {"node": "14", "field": "inputs.low_threshold", "default": 0.3},
      "high_threshold": {"node": "14", "field": "inputs.high_threshold", "default": 0.4},
      "strength": {"node": "9", "field": "inputs.strength", "default": 1.0},
      "input_image": {"node": "load_image", "field": "inputs.image"}
    },
    "models": {
      "diffusion_models": "z_image_turbo_nvfp4.safetensors",
      "text_encoders": "qwen_3_4b.safetensors",
      "vae": "ae.safetensors",
      "model_patches": "Z-Image-Turbo-Fun-Controlnet-Union.safetensors"
    },
    "model_downloads": {
      "Z-Image-Turbo-Fun-Controlnet-Union.safetensors": {
        "url": "https://huggingface.co/Comfy-Org/z_image_turbo/resolve/main/split_files/model_patches/Z-Image-Turbo-Fun-Controlnet-Union.safetensors",
        "category": "model_patches",
        "size_mb": 1300
      }
    }
  },
  "load_image": {
    "class_type": "LoadImage",
    "inputs": {
      "image": ""
    }
  },
  "15": {
    "class_type": "ImageScaleToTotalPixels",
    "inputs": {
      "image": ["load_image", 0],
      "upscale_method": "nearest-exact",
      "megapixels": 1,
      "resolution_steps": 1
    }
  },
  "14": {
    "class_type": "Canny",
    "inputs": {
      "image": ["15", 0],
      "low_threshold": 0.3,
      "high_threshold": 0.4
    }
  },
  "11": {
    "class_type": "GetImageSize",
    "inputs": {
      "image": ["14", 0]
    }
  },
  "2": {
    "class_type": "UNETLoader",
    "inputs": {
      "unet_name": "z_image_turbo_nvfp4.safetensors",
      "weight_dtype": "default"
    }
  },
  "1": {
    "class_type": "CLIPLoader",
    "inputs": {
      "clip_name": "qwen_3_4b.safetensors",
      "type": "lumina2",
      "device": "default"
    }
  },
  "3": {
    "class_type": "VAELoader",
    "inputs": {
      "vae_name": "ae.safetensors"
    }
  },
  "4": {
    "class_type": "ModelPatchLoader",
    "inputs": {
      "name": "Z-Image-Turbo-Fun-Controlnet-Union.safetensors"
    }
  },
  "9": {
    "class_type": "QwenImageDiffsynthControlnet",
    "inputs": {
      "model": ["2", 0],
      "model_patch": ["4", 0],
      "vae": ["3", 0],
      "image": ["14", 0],
      "strength": 1.0
    }
  },
  "6": {
    "class_type": "ModelSamplingAuraFlow",
    "inputs": {
      "model": ["9", 0],
      "shift": 3
    }
  },
  "12": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 0],
      "text": ""
    }
  },
  "8": {
    "class_type": "ConditioningZeroOut",
    "inputs": {
      "conditioning": ["12", 0]
    }
  },
  "10": {
    "class_type": "EmptySD3LatentImage",
    "inputs": {
      "width": ["11", 0],
      "height": ["11", 1],
      "batch_size": 1
    }
  },
  "7": {
    "class_type": "KSampler",
    "inputs": {
      "model": ["6", 0],
      "positive": ["12", 0],
      "negative": ["8", 0],
      "latent_image": ["10", 0],
      "seed": 0,
      "steps": 9,
      "cfg": 1,
      "sampler_name": "res_multistep",
      "scheduler": "simple",
      "denoise": 1
    }
  },
  "5": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["7", 0],
      "vae": ["3", 0]
    }
  },
  "save": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "canny-ctrl",
      "images": ["5", 0]
    }
  }
}
